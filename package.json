{
  "name": "jupyter-cli-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "JupyterLab frontend for jupyter-cli (bridge, copy-on-select, clipboard image, copy context)",
  "license": "MIT",
  "author": {
    "name": "Wenmin Wu",
    "email": "wuwenmin1991@gmail.com",
    "url": "https://github.com/wenmin-wu"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wenmin-wu/jupyter-cli.git"
  },
  "bugs": {
    "url": "https://github.com/wenmin-wu/jupyter-cli/issues"
  },
  "homepage": "https://github.com/wenmin-wu/jupyter-cli",
  "main": "lib/index.js",
  "style": "style/index.css",
  "scripts": {
    "build": "jlpm build:lib && jlpm build:labextension:dev",
    "build:prod": "jlpm clean && jlpm build:lib:prod && jlpm build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf jupyter_cli_extension/labextension",
    "install:extension": "jlpm build",
    "watch": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/cells": "^4.0.0",
    "@jupyterlab/coreutils": "^6.0.0",
    "@jupyterlab/docmanager": "^4.0.0",
    "@jupyterlab/fileeditor": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/settingregistry": "^4.0.0",
    "@jupyterlab/terminal": "^4.0.0",
    "@lumino/disposable": "^2.0.0",
    "@lumino/widgets": "^2.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "rimraf": "^5.0.1",
    "typescript": "~5.3.0"
  },
  "jupyterlab": {
    "discovery": {
      "server": {
        "managers": ["pip"],
        "base": {
          "name": "jupyter-cli"
        }
      }
    },
    "extension": true,
    "outputDir": "jupyter_cli_extension/labextension",
    "schemaDir": "schema"
  }
}
